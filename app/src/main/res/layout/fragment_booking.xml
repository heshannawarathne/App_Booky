<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/topSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_login_header"
            android:paddingStart="25dp"
            android:paddingTop="40dp"
            android:paddingEnd="25dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profileImg"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/img_15"
                android:layout_marginTop="20dp"
                app:civ_border_color="@color/white"
                app:civ_border_width="2dp" />

            <TextView
                android:id="@+id/userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/profileImg"
                android:layout_marginStart="15dp"
                android:layout_toEndOf="@id/profileImg"
                android:text="Heshan Nawarathna"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgbell"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@id/profileImg"
                android:src="@drawable/img_16"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/profileImg"
                android:layout_marginTop="20dp"
                android:text="Book your Seat"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-50dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_box_bg">

                    <ImageView
                        android:id="@+id/fIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/white_circle_bg"
                        android:padding="10dp"
                        android:src="@drawable/img_12" />

                    <TextView
                        android:id="@+id/fLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_toEndOf="@id/fIcon"
                        android:alpha="0.7"
                        android:text="From"
                        android:textSize="12sp" />

                    <AutoCompleteTextView
                        android:id="@+id/fromSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/fLabel"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="10dp"
                        android:layout_toEndOf="@id/fIcon"
                        android:background="@android:color/transparent"
                        android:hint="Select Origin"
                        android:inputType="none"
                        android:paddingTop="5dp"
                        android:textColor="@color/book_item_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_box_bg">

                    <ImageView
                        android:id="@+id/tIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/white_circle_bg"
                        android:padding="10dp"
                        android:src="@drawable/img_14" />

                    <TextView
                        android:id="@+id/tLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="8dp"
                        android:layout_toEndOf="@id/tIcon"
                        android:alpha="0.7"
                        android:text="To"
                        android:textSize="12sp" />

                    <AutoCompleteTextView
                        android:id="@+id/toSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tLabel"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="10dp"
                        android:layout_toEndOf="@id/tIcon"
                        android:background="@android:color/transparent"
                        android:hint="Select Destination"
                        android:inputType="none"
                        android:paddingTop="5dp"
                        android:textColor="@color/book_item_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/dateBox"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/input_box_bg"
                    android:backgroundTint="@color/others_boxes_field"
                    android:paddingStart="15dp">

                    <TextView
                        android:id="@+id/dLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:alpha="0.7"
                        android:text="Date"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/dateValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/dLabel"
                        android:text="20 July 2023"
                        android:textColor="@color/book_item_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSearch"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/button_teal_rounded"
                    android:text="Search Buses"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today All Buses"
                android:textColor="@color/book_item_color"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/seeAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="See All"
                android:textColor="@color/primary_teal"
                android:textStyle="bold" />
        </RelativeLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/busRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topSection"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>