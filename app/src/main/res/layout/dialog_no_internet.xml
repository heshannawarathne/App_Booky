<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg_white"
    android:orientation="vertical"
    android:padding="25dp"
    android:gravity="center">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/disconnect" /> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="No Connection!"
    android:textSize="22sp"
    android:textStyle="bold"
    android:textColor="@color/white_02"
    android:layout_marginTop="15dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please check your internet and try again."
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:textColor="@color/white_02"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:background="@drawable/call_btn_circle"
        android:text="Refresh"
        android:textColor="#FFFFFF"/>
</LinearLayout>