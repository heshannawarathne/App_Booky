<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F8"
    tools:context=".OtpActivity">

    <ImageView
        android:id="@+id/otpImg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintHeight_percent="0.40"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/img_4" />

    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bottom_fade_gradient"
        app:layout_constraintBottom_toBottomOf="@+id/otpImg" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-30dp"
        android:background="@drawable/login_content_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/otpImg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/tvVerifyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Verify OTP"
                android:textColor="#1A1A1A"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOtpDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Security first! Enter the 6-digit code \nsent to your phone"
                android:textColor="#666666"
                android:textSize="15sp"
                android:lineHeight="22sp"/>

            <LinearLayout
                android:id="@+id/otpContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="horizontal">

                <EditText android:id="@+id/otp1" style="@style/ModernOtpBox" />
                <EditText android:id="@+id/otp2" style="@style/ModernOtpBox" />
                <EditText android:id="@+id/otp3" style="@style/ModernOtpBox" />
                <EditText android:id="@+id/otp4" style="@style/ModernOtpBox" />
                <EditText android:id="@+id/otp5" style="@style/ModernOtpBox" />
                <EditText android:id="@+id/otp6" style="@style/ModernOtpBox" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="40dp"
                android:text="Verify &amp; Proceed"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                android:backgroundTint="#3A7B73"
                app:elevation="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDidntReceive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Didn’t receive the code?"
                    android:textColor="#999999"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvResendCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:padding="8dp"
                    android:text="Resend New Code"
                    android:textColor="#3A7B73"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>